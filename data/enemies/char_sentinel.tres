[gd_resource type="Resource" script_class="EnemyData" load_steps=6 format=3]

[ext_resource type="Script" path="res://Path-of-Embers/data/EnemyData.gd" id="1_enemydata"]
[ext_resource type="Script" path="res://Path-of-Embers/data/EffectData.gd" id="2_effectdata"]

[sub_resource type="Resource" id="EffectData_1" script_class="EffectData"]
script = ExtResource("2_effectdata")
effect_type = "damage"
params = {"amount": 12}

[sub_resource type="Resource" id="EffectData_2" script_class="EffectData"]
script = ExtResource("2_effectdata")
effect_type = "damage"
params = {"amount": 10}

[sub_resource type="Resource" id="EffectData_3" script_class="EffectData"]
script = ExtResource("2_effectdata")
effect_type = "vulnerable"
params = {"duration": 1}

[sub_resource type="Resource" id="EffectData_4" script_class="EffectData"]
script = ExtResource("2_effectdata")
effect_type = "block"
params = {"amount": 12}

[resource]
script = ExtResource("1_enemydata")
id = "char_sentinel"
display_name = "Char Sentinel"
name = "Char Sentinel"
act = 1
enemy_type = 1
min_hp = 70
max_hp = 80
moves = [{
"effects": [SubResource("EffectData_1")],
"id": "move_1",
"telegraph_text": "Guard Crush 12",
"timer": 5
}, {
"effects": [SubResource("EffectData_2"), SubResource("EffectData_3")],
"id": "move_2",
"telegraph_text": "Sentinel Strike 10 + Vulnerable",
"timer": 4
}, {
"effects": [SubResource("EffectData_4")],
"id": "move_3",
"telegraph_text": "Fortify",
"timer": 3
}]

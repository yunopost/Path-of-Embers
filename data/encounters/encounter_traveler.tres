"reward_card_choices": 1,
"reward_upgrade_count": 0
}, {
"id": "rob",
"label": "Take their coin",
"effects_text": "You help yourself to their gold and press on.",
"reward_gold": 30,
"reward_heal": 0,
"reward_card_choices": 0,
"reward_upgrade_count": 0
}, {
"id": "pass_by",
"label": "Pass by quietly",
"effects_text": "You move on. The road demands it.",

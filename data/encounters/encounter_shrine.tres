"reward_upgrade_count": 0
}, {
"id": "offer_strength",
"label": "Offer your strength",
"effects_text": "You channel your power into the shrine. It returns a focused upgrade.",
"reward_gold": 0,
"reward_heal": 0,
"reward_card_choices": 0,
"reward_upgrade_count": 1
}, {
"id": "leave_undisturbed",
"label": "Leave it undisturbed",
"effects_text": "Showing respect, you back away. A coin appears at the base of the shrine.",
